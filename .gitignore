# ==============================================================================
# éozoré — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# OS / Editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------------------------
# Environment variables (NUNCA commitar com valores reais)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development

# Credenciais e chaves privadas
*.pem
*.key
*.p12
*.json.enc
service-account*.json
*-credentials.json

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# ------------------------------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Terraform
# ------------------------------------------------------------------------------
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfplan
infra/terraform.tfvars
*.auto.tfvars

# ------------------------------------------------------------------------------
# Firebase
# ------------------------------------------------------------------------------
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
*.log
docker-compose.override.yml

# ------------------------------------------------------------------------------
# Documentos internos de planejamento (não publicar)
# ------------------------------------------------------------------------------
planejamento.md
artigos.md
plano.md
apresentacao-kickoff.html
eozoreIA/

# ------------------------------------------------------------------------------
# Kiro specs (workflow interno de desenvolvimento)
# ------------------------------------------------------------------------------
.kiro/
