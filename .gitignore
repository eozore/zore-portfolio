# ==============================================================================
# éozoré Portfólio — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# OS / Editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------------------------
# Environment variables (NUNCA commitar com valores reais)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development

# Credenciais e chaves privadas
*.pem
*.key
*.p12
*.json.enc
service-account*.json
*-credentials.json

# ------------------------------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Python (caso algum script local)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
venv/
.venv/

# ------------------------------------------------------------------------------
# Firebase
# ------------------------------------------------------------------------------
.firebase/
firebase-debug.log
firestore-debug.log

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
*.log
docker-compose.override.yml

# ------------------------------------------------------------------------------
# Documentos internos (não publicar)
# ------------------------------------------------------------------------------
planejamento.md
artigos.md
plano.md
apresentacao-kickoff.html
eozoreIA/

# ------------------------------------------------------------------------------
# Kiro specs (workflow interno)
# ------------------------------------------------------------------------------
.kiro/

# ------------------------------------------------------------------------------
# Passo a Passo (Gerador de Motion HTML)
# ------------------------------------------------------------------------------
passoapasso/node_modules/
passoapasso/uploads/
passoapasso/temp/
passoapasso/*.zip

# ------------------------------------------------------------------------------
# Pastas de Desenvolvimento Local (Ferramentas Privadas / Rascunhos)
# ------------------------------------------------------------------------------
tool-*/
