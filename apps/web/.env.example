# Firebase Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# Article API authentication
ARTICLE_API_KEY=your-secret-api-key

# Base URL for sitemap and article URLs
NEXT_PUBLIC_BASE_URL=https://eozore.com

# ── CSM Tool (Content Studio Manager) ──────────────────────────
# SHA-256 hash da sua senha de acesso ao CSM Tool
# Gerar: echo -n "SuaSenha" | shasum -a 256
CSM_PASSWORD_HASH=coloque-aqui-o-hash-sha256-da-sua-senha

# A geração de conteúdo usa Vertex AI com Application Default Credentials (ADC).
# Não é necessária uma API key separada — usa as mesmas credenciais do Firebase Admin.
#
# Para rodar localmente:
#   gcloud auth application-default login
#   (e garanta que o FIREBASE_PROJECT_ID está setado com um projeto que tem Vertex AI ativado)
#
# No Cloud Run: automático via service account da instância.
#
# Para ativar o Vertex AI no projeto GCP:
#   gcloud services enable aiplatform.googleapis.com
