# ==============================================================================
# Agentic Marketing Platform — Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais no repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# GCP / Projeto
# ------------------------------------------------------------------------------

# ID do projeto Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id

# Região GCP para deploy dos serviços (Cloud Run, Firestore, etc.)
GCP_LOCATION=us-central1

# Habilita uso do Vertex AI como backend para modelos Gemini
GOOGLE_GENAI_USE_VERTEXAI=true

# ------------------------------------------------------------------------------
# Firebase
# ------------------------------------------------------------------------------

# ID do projeto Firebase (geralmente igual ao GCP_PROJECT_ID)
FIREBASE_PROJECT_ID=your-firebase-project-id

# API Key do Firebase (público, usado no frontend)
FIREBASE_API_KEY=AIzaSy...your-firebase-api-key

# Auth domain do Firebase
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Storage bucket do Firebase
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Messaging sender ID do Firebase
FIREBASE_MESSAGING_SENDER_ID=123456789012

# App ID do Firebase
FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ------------------------------------------------------------------------------
# URLs dos Serviços (Cloud Run)
# ------------------------------------------------------------------------------

# URL do serviço de agentes (FastAPI + ADK) no Cloud Run
AGENTS_SERVICE_URL=https://agents-xxxxxxxxxx-uc.a.run.app

# URL do serviço Postiz (MCP) — rede interna, sem acesso público
POSTIZ_BASE_URL=https://postiz-xxxxxxxxxx-uc.a.run.app

# URL do serviço de renderização (Puppeteer headless) — rede interna
RENDERER_SERVICE_URL=https://renderer-xxxxxxxxxx-uc.a.run.app

# ------------------------------------------------------------------------------
# Postiz (MCP Server)
# ------------------------------------------------------------------------------

# API Key para autenticação com o servidor Postiz
POSTIZ_API_KEY=your-postiz-api-key

# ------------------------------------------------------------------------------
# Secret Manager
# ------------------------------------------------------------------------------

# Prefixo usado para organizar segredos no Secret Manager (tokens OAuth por tenant)
SECRET_MANAGER_PREFIX=social-tokens

# ------------------------------------------------------------------------------
# OAuth — Meta (Instagram / Facebook)
# ------------------------------------------------------------------------------

# App ID do aplicativo Meta (Facebook Developer Portal)
META_APP_ID=123456789012345

# App Secret do aplicativo Meta
META_APP_SECRET=your-meta-app-secret

# ------------------------------------------------------------------------------
# OAuth — LinkedIn
# ------------------------------------------------------------------------------

# Client ID do aplicativo LinkedIn (LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=your-linkedin-client-id

# Client Secret do aplicativo LinkedIn
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ------------------------------------------------------------------------------
# OAuth — YouTube (Google)
# ------------------------------------------------------------------------------

# OAuth Client ID para YouTube Data API
YOUTUBE_OAUTH_CLIENT_ID=your-youtube-oauth-client-id.apps.googleusercontent.com

# OAuth Client Secret para YouTube Data API
YOUTUBE_OAUTH_CLIENT_SECRET=your-youtube-oauth-client-secret

# ------------------------------------------------------------------------------
# Stripe (Fase 2 — Billing/Subscriptions)
# ------------------------------------------------------------------------------

# Secret key da conta Stripe (sk_test_... ou sk_live_...)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Webhook secret para validar eventos do Stripe (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ------------------------------------------------------------------------------
# Modelos de IA por Agente (variáveis MODEL_*)
# Se não definidas, usam os defaults em apps/agents/models.py:
#   Pro: director, strategist, writer, reviewer
#   Flash: researcher, producer, publisher, analyst
# ------------------------------------------------------------------------------

# Modelo para o agente Diretor (orquestrador principal)
MODEL_DIRECTOR=gemini-2.5-pro

# Modelo para o agente Estrategista (calendário e planejamento)
MODEL_STRATEGIST=gemini-2.5-pro

# Modelo para o agente Pesquisador (tendências e oportunidades)
MODEL_RESEARCHER=gemini-2.5-flash

# Modelo para o agente Roteirista (produção de conteúdo)
MODEL_WRITER=gemini-2.5-pro

# Modelo para o agente Produtor de Mídia (assets visuais e templates HTML)
MODEL_PRODUCER=gemini-2.5-flash

# Modelo para o agente Revisor (validação de qualidade)
MODEL_REVIEWER=gemini-2.5-pro

# Modelo para o agente Publicador (gate de publicação e deploy)
MODEL_PUBLISHER=gemini-2.5-flash

# Modelo para o agente Analista (métricas pós-publicação)
MODEL_ANALYST=gemini-2.5-flash
