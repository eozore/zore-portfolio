rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // =========================================================================
    // Helper Functions
    // =========================================================================

    // Verifica se o usuário autenticado pertence ao tenant (via custom claim)
    function isTenantMember(tenantId) {
      return request.auth != null
        && request.auth.token.tenantId == tenantId;
    }

    // Verifica se a requisição vem do backend com credenciais administrativas
    function isBackend() {
      return request.auth != null
        && request.auth.token.admin == true;
    }

    // Verifica se o campo tenantId não foi alterado após criação
    function tenantIdUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tenantId']);
    }

    // =========================================================================
    // Tenant Root Document
    // =========================================================================
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if request.auth != null && request.auth.uid == tenantId;
      allow update: if isTenantMember(tenantId)
        && tenantIdUnchanged();

      // -----------------------------------------------------------------------
      // Settings: leitura pelo tenant, escrita apenas pelo backend
      // -----------------------------------------------------------------------
      match /settings/{document=**} {
        allow read: if isTenantMember(tenantId);
        allow write: if isBackend();
      }

      // -----------------------------------------------------------------------
      // Connections: leitura pelo tenant, escrita pelo backend
      // -----------------------------------------------------------------------
      match /connections/{platform} {
        allow read: if isTenantMember(tenantId);
        allow write: if isBackend();
      }

      // -----------------------------------------------------------------------
      // Articles: leitura/escrita pelo tenant, mas campo 'status' só pelo backend
      // -----------------------------------------------------------------------
      match /articles/{articleId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) || isBackend();
        allow update: if isBackend()
          || (isTenantMember(tenantId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
            && tenantIdUnchanged());

        // Versions subcoleção
        match /versions/{versionId} {
          allow read: if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId) || isBackend();
        }
      }

      // -----------------------------------------------------------------------
      // Runs e Events: read-only para tenant, escrita pelo backend
      // -----------------------------------------------------------------------
      match /runs/{runId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isBackend();

        match /events/{eventId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isBackend();
        }
      }

      // -----------------------------------------------------------------------
      // Approvals: criação pelo backend, atualização restrita pelo tenant
      // -----------------------------------------------------------------------
      match /approvals/{approvalId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isBackend();
        allow update: if isTenantMember(tenantId)
          && tenantIdUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'decidedBy', 'decidedAt']);
      }

      // -----------------------------------------------------------------------
      // Templates: biblioteca de templates HTML por tenant
      // -----------------------------------------------------------------------
      match /templates/{templateId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) || isBackend();
        allow update: if (isTenantMember(tenantId) || isBackend())
          && tenantIdUnchanged();
        allow delete: if isTenantMember(tenantId);
      }

      // -----------------------------------------------------------------------
      // Calendar Items
      // -----------------------------------------------------------------------
      match /calendar/{itemId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) || isBackend();
        allow update: if (isTenantMember(tenantId) || isBackend())
          && tenantIdUnchanged();
        allow delete: if isTenantMember(tenantId) || isBackend();
      }

      // -----------------------------------------------------------------------
      // Usage (métricas de consumo)
      // -----------------------------------------------------------------------
      match /usage/{period} {
        allow read: if isTenantMember(tenantId);
        allow write: if isBackend();
      }

      // -----------------------------------------------------------------------
      // Members (multi-tenant, membros do tenant)
      // -----------------------------------------------------------------------
      match /members/{uid} {
        allow read: if isTenantMember(tenantId);
        allow write: if isBackend();
      }
    }

    // =========================================================================
    // Deny all other paths by default (Firestore denies by default)
    // =========================================================================
  }
}
